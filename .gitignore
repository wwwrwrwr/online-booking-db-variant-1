cat > .gitignore << 'EOF'
# ================= ОПЕРАЦИОННЫЕ СИСТЕМЫ =================
.DS_Store
Thumbs.db
desktop.ini
*.lnk

# ================= РЕДАКТОРЫ И IDE =================
.vscode/
.idea/
*~
*.swp
*.swo

# ================= ВРЕМЕННЫЕ ФАЙЛЫ И ЛОГИ =================
*.tmp
*.log
logs/
temp/

# ================= РЕЗЕРВНЫЕ КОПИИ =================
*.sql.gz
*.dump
*.bak
backups/

# ================= КОНФИГУРАЦИИ =================
.env
.env.*
config.local.*

# ================= СИСТЕМНЫЕ =================
.git/
EOF
